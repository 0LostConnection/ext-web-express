# Copie para .env e ajuste se precisar.
# A porta deve ser a mesma usada em API_PROXY_TARGET no frontend (ex.: frontend/.env.development).

API_PORT=3000

# Opcional — origens permitidas (várias separadas por vírgula). Omitir em dev costuma bastar com CORS reflexivo.
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
